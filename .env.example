# =============================================================================
# Lumen frontend — copy to `.env.local` or `.env` and adjust (never commit secrets).
# Only variables prefixed with VITE_ are exposed to browser code (see Vite docs).
# =============================================================================

# --- Hosted Lumen / Base44 platform (required for real auth + API outside demo) ---
# App ID from the Lumen builder (or legacy Base44 app id).
VITE_LUMEN_APP_ID=

# Backend / app base URL (Vite plugin may proxy `/api` to this host in dev).
VITE_LUMEN_APP_BASE_URL=

# Optional: functions runtime version if your project expects it.
VITE_LUMEN_FUNCTIONS_VERSION=

# --- Demo / local presentation mode ---
# When `true`, demo mode is forced on at build time unless the user opts out with `?demo=false`.
# Leave unset or `false` for normal behavior; session + URL still control demo (see README).
VITE_DEMO_MODE=false

# --- Legacy aliases (optional) ---
# If you still have tooling that sets Base44 names, you can use these; otherwise prefer VITE_LUMEN_*.
# VITE_BASE44_APP_ID=
# VITE_BASE44_APP_BASE_URL=
# VITE_BASE44_FUNCTIONS_VERSION=
